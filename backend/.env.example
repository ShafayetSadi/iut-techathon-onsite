# Copy to `backend/.env` and fill in. That file is git-ignored.
#
# The ROBOT_ prefix is required: Settings uses env_prefix="ROBOT_", so a bare
# ELEVENLABS_API_KEY is silently ignored.
#
# Never expose this to the frontend. Next.js inlines any NEXT_PUBLIC_* variable
# into the client bundle, which is why audio round-trips through this backend
# instead of the browser calling ElevenLabs directly.
ROBOT_ELEVENLABS_API_KEY=

# Optional overrides — defaults live in app/core/config.py.
# ROBOT_ELEVENLABS_STT_MODEL=scribe_v1
# ROBOT_IK_TOLERANCE_M=0.002
