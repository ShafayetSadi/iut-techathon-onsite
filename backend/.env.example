# Copy to `backend/.env` and fill in. That file is git-ignored.
#
# The ROBOT_ prefix is required: Settings uses env_prefix="ROBOT_", so bare
# provider variable names are silently ignored.
#
# Never expose these keys to the frontend. Next.js inlines any NEXT_PUBLIC_*
# variable into the client bundle, so provider calls go through this backend.

# Speech-to-text (Phase 3)
ROBOT_ELEVENLABS_API_KEY=

# Optional speech overrides. Defaults live in app/core/config.py.
# scribe_v1 rejects keyterms, so selecting it disables recognition biasing.
# ROBOT_ELEVENLABS_STT_MODEL=scribe_v2
# ROBOT_ELEVENLABS_KEYTERMS_ENABLED=true
# ROBOT_ELEVENLABS_LANGUAGE_CODE=eng
# ROBOT_IK_TOLERANCE_M=0.002

# Agentic natural-language planning (Phase 3B)
ROBOT_OPENROUTER_API_KEY=
# The model must accept tools AND a strict json_schema response_format in the
# same request — app/agent/service.py always sends both. That rules out more
# models than it sounds like. Checked against the live AgentDraft schema:
#   google/gemini-2.5-flash       works
#   google/gemini-2.5-flash-lite  "Function calling with a response mime type
#                                  'application/json' is unsupported"
#   anthropic/claude-sonnet-4.5   strict mode rejects the schema's maxItems
#   openai/gpt-4.1-mini           strict mode rejects the schema's oneOf
ROBOT_OPENROUTER_MODEL=google/gemini-2.5-flash
# Optional attribution headers for OpenRouter rankings.
ROBOT_OPENROUTER_HTTP_REFERER=http://localhost:3000
ROBOT_OPENROUTER_APP_TITLE=Vantage Dry Run
